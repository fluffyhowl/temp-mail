{
  "name": "rdhx-email",
  "version": "0.1.0",
  "private": true,
  "description": "RDHX Email Cloudflare Workers and Vue application baseline",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "test": "node tests/config-router.test.js",
    "verify:schema": "node tests/verify-schema.js",
    "verify:static": "node tests/verify-static.js",
    "verify": "npm test && npm run verify:schema && npm run verify:static && npm run build",
    "preview": "vite preview --host 127.0.0.1",
    "worker:dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vueuse/core": "^10.11.1",
    "autoprefixer": "^10.4.21",
    "pinia": "^2.3.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "wrangler": "^4.75.0"
  },
  "devDependencies": {}
}
